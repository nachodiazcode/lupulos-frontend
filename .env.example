# Example environment variables for Lúpulos Backend
#
# Notes:
# - Do NOT commit real secrets.
# - NEXT_PUBLIC_* variables are exposed to the browser.
# - API URL must NOT include a trailing /api (the app appends it internally).

# Backend base URL (examples)
# Local:
NEXT_PUBLIC_API_URL=http://localhost:3940
# DuckDNS (HTTPS):
# NEXT_PUBLIC_API_URL=https://lupulos-dev.duckdns.org

# ------------------------------------------------------------------------------
# Vercel proxy mode (recommended for GitHub -> Vercel deployments)
# ------------------------------------------------------------------------------
# 1) Keep frontend calls relative to /api:
# NEXT_PUBLIC_API_URL=/api
#
# 2) Configure the backend target as a server-side env var in Vercel:
# API_PROXY_TARGET=https://tu-backend.vercel.app
#
# The app will rewrite:
# - /api/*      -> ${API_PROXY_TARGET}/api/*
# - /uploads/*  -> ${API_PROXY_TARGET}/uploads/*
